# =====================================================================
# DeepTutor Environment Configuration for Dokploy Deployment
# =====================================================================

# ---------------------------------------------------------------------
# 1. Ports
# ---------------------------------------------------------------------
BACKEND_PORT=8001
FRONTEND_PORT=3782
POCKETBASE_PORT=8090

# ---------------------------------------------------------------------
# 2. LLM (Required)
# ---------------------------------------------------------------------
# Using LiteRT-LM bridge service (runs in Docker Compose)
LLM_BINDING=litertlm
LLM_MODEL=gemma-4-E2B-it
LLM_API_KEY=sk-no-key-required
LLM_HOST=http://litertlm:8000/v1
#LLM_API_VERSION=
#LLM_REASONING_EFFORT=

# ---------------------------------------------------------------------
# LiteRT-LM Bridge (Optional - on-device Gemma models)
# ---------------------------------------------------------------------
# Leave empty to use default: ./data/models/gemma-4-E2B-it.litertlm
# The model is downloaded automatically by the Docker service
LITERTLM_MODEL_PATH=
LITERTLM_HOST=0.0.0.0
LITERTLM_PORT=8000
LITERTLM_MODEL_ID=gemma-4-E2B-it
LITERTLM_LOG_LEVEL=INFO

# ---------------------------------------------------------------------
# 3. Embedding (Required for knowledge base / RAG)
# ---------------------------------------------------------------------
# IMPORTANT: You need a real API key for embedding, or use a local alternative
# Options:
#   1. Use OpenAI (requires paid API key)
#   2. Use a free alternative like Jina AI, SiliconFlow, or local Ollama
#   3. Disable knowledge base features if not needed

# Option 1: OpenAI (requires real API key)
EMBEDDING_BINDING=openai
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_API_KEY=your-openai-api-key-here
EMBEDDING_HOST=https://api.openai.com/v1/embeddings
#EMBEDDING_API_VERSION=
# Leave empty to let DeepTutor auto-detect dimension
EMBEDDING_DIMENSION=
#EMBEDDING_SEND_DIMENSIONS=

# Option 2: Jina AI (free tier available)
# EMBEDDING_BINDING=jina
# EMBEDDING_MODEL=jina-embeddings-v3
# EMBEDDING_API_KEY=your-jina-api-key-here
# EMBEDDING_HOST=https://api.jina.ai/v1/embeddings
# EMBEDDING_DIMENSION=1024

# Option 3: SiliconFlow (free tier available)
# EMBEDDING_BINDING=siliconflow
# EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
# EMBEDDING_API_KEY=your-siliconflow-api-key-here
# EMBEDDING_HOST=https://api.siliconflow.cn/v1/embeddings
# EMBEDDING_DIMENSION=1024

# Option 4: Local Ollama (if you have Ollama running)
# EMBEDDING_BINDING=ollama
# EMBEDDING_MODEL=nomic-embed-text
# EMBEDDING_API_KEY=
# EMBEDDING_HOST=http://ollama:11434/api/embed
# EMBEDDING_DIMENSION=768

# Per-provider API-key fallbacks
SILICONFLOW_API_KEY=
DASHSCOPE_API_KEY=
COHERE_API_KEY=
JINA_API_KEY=
GEMINI_API_KEY=

# ---------------------------------------------------------------------
# 4. Web Search (Optional)
# ---------------------------------------------------------------------
# Providers: brave, tavily, serper, jina, perplexity, searxng, duckduckgo
SEARCH_PROVIDER=
SEARCH_API_KEY=
SEARCH_BASE_URL=
SEARCH_PROXY=

# ---------------------------------------------------------------------
# 5. Networking & Frontend (Docker / remote deployments)
# ---------------------------------------------------------------------
# IMPORTANT: Set this to your server's public URL for remote deployment
# Example: https://your-domain.com or http://your-server-ip:8001
NEXT_PUBLIC_API_BASE_EXTERNAL=
# Alternative direct backend URL (usually leave blank)
NEXT_PUBLIC_API_BASE=
# Optional extra CORS origin
CORS_ORIGIN=

# ---------------------------------------------------------------------
# 6. Security
# ---------------------------------------------------------------------
# Keep this false in production
DISABLE_SSL_VERIFY=false

# ---------------------------------------------------------------------
# 7. Authentication & Multi-User
# ---------------------------------------------------------------------
# Set to true for public deployments
AUTH_ENABLED=false
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
AUTH_SECRET=
AUTH_TOKEN_EXPIRE_HOURS=24
AUTH_COOKIE_SECURE=false
NEXT_PUBLIC_AUTH_ENABLED=

# Single-user setup (optional)
AUTH_USERNAME=
AUTH_PASSWORD_HASH=

# ---------------------------------------------------------------------
# 8. PocketBase sidecar (Optional auth + storage)
# ---------------------------------------------------------------------
# Leave blank to use built-in SQLite/JSON backend (recommended)
POCKETBASE_URL=
POCKETBASE_ADMIN_EMAIL=
POCKETBASE_ADMIN_PASSWORD=
POCKETBASE_EXTERNAL_URL=

# ---------------------------------------------------------------------
# 9. Storage / Attachments (Optional)
# ---------------------------------------------------------------------
# Leave blank for default Docker deployment
CHAT_ATTACHMENT_DIR=
